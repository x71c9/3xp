{
  "name": "3xp",
  "version": "1.2.4",
  "description": "A TypeScript library providing runtime object validation with automatic compile-time type inference. Supports primitives, nested objects, arrays, optional fields, and enum values with strict or permissive validation modes.",
  "main": "dist/index.js",
  "repository": "git@github.com:x71c9/3xp.git",
  "author": "x71c9 <108585118+x71c9@users.noreply.github.com>",
  "license": "UNLICENSED",
  "private": false,
  "scripts": {
    "precommit": "npx lint-staged --allow-empty",
    "prepare": "npx husky install .repo/husky && npx husky set .repo/husky/pre-commit \"npm run precommit\"",
    "push:patch": "sh ./scripts/version.sh patch",
    "push:minor": "sh ./scripts/version.sh minor",
    "push:major": "sh ./scripts/version.sh major",
    "test:watch:verbose": "NODE_ENV=dev npx jest --coverage --watch --verbose=true",
    "test:watch": "NODE_ENV=dev npx jest --coverage --watch --verbose=false --silent",
    "test:verbose": "npx jest --coverage --verbose=true",
    "test": "npx jest --coverage --verbose=false --silent",
    "dev:client": "npx live-server client",
    "dev:base": "node ./dist/run.js",
    "dev:run": "npx tsc-watch --onSuccess \" npm run dev:base\"",
    "dev": "npx tsc -w",
    "build": "npx tsc -b",
    "pretty": "npx prettier --write \"src/**/*.{js,ts,json}\""
  },
  "lint-staged": {
    "src/**/*.{js,ts,json}": [
      "npx prettier --write"
    ]
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-json": "^4.0.1",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.2.7",
    "prettier": "3.8.1",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-watch": "^7.2.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "i0n": "^0.9.0",
    "w3i": "^0.3.2"
  }
}
